// ─── Main Component ───────────────────────────────────────────
export default function CustomizePage() {
  const router    = useRouter();
  const addToCart = useCartStore((s) => s.addItem);

  const [productId,  setProductId]  = useState<ProductId>("tshirt");
  const [prodColor,  setProdColor]  = useState("#F5F5F0");
  const [view,       setView]       = useState<"front" | "back">("front");
  const [size,       setSize]       = useState("M");

  const [elements,   setElements]   = useState<DesignElement[]>([]);
  const [selected,   setSelected]   = useState<string | null>(null);
  const [tool,       setTool]       = useState<"select"|"text"|"sticker"|"upload">("select");
  const [history,    setHistory]    = useState<DesignElement[][]>([[]]);
  const [histIdx,    setHistIdx]    = useState(0);
  const [stickerPack,setStickerPack]= useState("تعابير");
  const [showGuide,  setShowGuide]  = useState(true);

  const [textInput,  setTextInput]  = useState("نصك هنا");
  const [textColor,  setTextColor]  = useState("#1A1A1A");
  const [fontSize,   setFontSize]   = useState(28);
  const [fontBold,   setFontBold]   = useState(false);
  const [fontFamily, setFontFamily] = useState("Tajawal");

  const fileInput = useRef<HTMLInputElement>(null);
  const dragging  = useRef<{ id:string; ox:number; oy:number } | null>(null);
  const canvasRef = useRef<HTMLDivElement>(null);

  const product = PRODUCTS[productId];
  const sizeScale = SIZE_SCALE[size] ?? 1.0;

  // ── History ────────────────────────────────────────────────
  const pushHistory = useCallback((els: DesignElement[]) => {
    setHistory(h => {
      const next = [...h.slice(0, histIdx + 1), [...els]];
      setHistIdx(next.length - 1);
      return next;
    });
  }, [histIdx]);

  const undo = () => {
    if (histIdx > 0) {
      setHistIdx(i => i - 1);
      setElements([...history[histIdx - 1]]);
    }
  };
  const redo = () => {
    if (histIdx < history.length - 1) {
      setHistIdx(i => i + 1);
      setElements([...history[histIdx + 1]]);
    }
  };

  // ── Element management ─────────────────────────────────────
  const addElement = (el: Omit<DesignElement, "id"|"x"|"y"|"rotation"|"scale">) => {
    const newEl: DesignElement = {
      ...el, id: Date.now().toString(),
      x: 210, y: 220, rotation: 0, scale: 1,
    };
    const next = [...elements, newEl];
    setElements(next); pushHistory(next);
    setSelected(newEl.id); setTool("select");
  };

  const addText = () => {
    if (!textInput.trim()) return;
    addElement({ type:"text", content:textInput, color:textColor, fontSize, bold:fontBold, fontFamily });
  };

  const addSticker = (emoji: string) =>
    addElement({ type:"sticker", content:emoji, color:"", fontSize:52, bold:false, fontFamily:"serif" });

  const deleteSelected = () => {
    const next = elements.filter(e => e.id !== selected);
    setElements(next); pushHistory(next); setSelected(null);
  };

  const clearAll = () => { setElements([]); pushHistory([]); setSelected(null); };

  // ── Drag ───────────────────────────────────────────────────
  const onMouseDown = (e: React.MouseEvent, id: string) => {
    e.stopPropagation(); setSelected(id);
    const el = elements.find(x => x.id === id)!;
    dragging.current = { id, ox: e.clientX - el.x, oy: e.clientY - el.y };
  };

  const onMouseMove = (e: React.MouseEvent) => {
    if (!dragging.current) return;
    const { id, ox, oy } = dragging.current;
    setElements(prev => prev.map(el =>
      el.id === id ? { ...el, x: e.clientX - ox, y: e.clientY - oy } : el
    ));
  };

  const onMouseUp = () => {
    if (dragging.current) { pushHistory(elements); dragging.current = null; }
  };

  // ── Mouse Wheel to resize ──────────────────────────────────
  const onWheel = useCallback((e: React.WheelEvent) => {
    if (!selected) return;
    e.preventDefault();
    const delta = e.deltaY > 0 ? -0.06 : 0.06;
    setElements(prev => {
      const next = prev.map(el =>
        el.id === selected
          ? { ...el, scale: Math.max(0.15, Math.min(5, el.scale + delta)) }
          : el
      );
      return next;
    });
  }, [selected]);

  // ── Image upload ───────────────────────────────────────────
  const handleImageUpload = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0]; if (!file) return;
    const reader = new FileReader();
    reader.onload = (ev) => addElement({
      type:"image", content:ev.target?.result as string,
      color:"", fontSize:90, bold:false, fontFamily:"",
    });
    reader.readAsDataURL(file);
  };

  const scaleSelected = (delta: number) => {
    setElements(prev => prev.map(el =>
      el.id === selected ? { ...el, scale: Math.max(0.15, Math.min(5, el.scale + delta)) } : el
    ));
  };

  const rotateSelected = (deg: number) => {
    setElements(prev => prev.map(el =>
      el.id === selected ? { ...el, rotation: (el.rotation + deg) % 360 } : el
    ));
  };

  const handleAddToCart = () => {
    (addToCart as any)({
      id: Date.now(),
      nameAr: `${product.label} مخصص`,
      nameEn: "Custom Item",
      brand: "VŌGU Custom",
      price: product.price,
      grad: "from-[#C9A86E] to-[#9A7848]",
      image: "",
      size, color: prodColor, colorHex: prodColor, quantity: 1,
    });
    router.push("/cart");
  };

  const selectedEl = elements.find(e => e.id === selected);
  const svgHtml = view === "front"
    ? product.front(prodColor)
    : product.back(prodColor);

  // ── Render ─────────────────────────────────────────────────
  return (
    <div className="min-h-screen bg-[#070707]" dir="rtl" style={{ fontFamily:"Tajawal, sans-serif" }}>

      {/* ═══ Header ═══ */}
      <div style={{
        borderBottom:"1px solid #1A1A1A", padding:"12px 20px",
        display:"flex", alignItems:"center", justifyContent:"space-between",
        background:"#0A0A0A",
      }}>
        <div>
          <p style={{ fontSize:9, color:"#C9A86E", letterSpacing:"0.3em", marginBottom:1 }}>VŌGU CUSTOM</p>
          <h1 style={{ fontFamily:"'Cormorant Garant', serif", fontSize:22, fontWeight:400, color:"#EDE8DF" }}>
            مصمّم الأزياء الشخصي
          </h1>
        </div>

        <div style={{ display:"flex", alignItems:"center", gap:8 }}>
          {/* Undo/Redo */}
          {[
            { fn:undo, dis:histIdx===0, icon:<RotateCcw size={13}/>, tip:"تراجع (Ctrl+Z)" },
            { fn:redo, dis:histIdx===history.length-1, icon:<RotateCcw size={13} style={{transform:"scaleX(-1)"}}/>, tip:"إعادة" },
          ].map(({ fn, dis, icon, tip }) => (
            <button key={tip} onClick={fn} disabled={dis} title={tip} style={{
              ...iconBtn, width:34, height:34,
              opacity: dis ? 0.3 : 1,
            }}>{icon}</button>
          ))}

          {/* View toggle */}
          <div style={{ display:"flex", background:"#121212", border:"1px solid #1A1A1A", borderRadius:9, overflow:"hidden" }}>
            {(["front","back"] as const).map(v => (
              <button key={v} onClick={() => setView(v)} style={{
                padding:"7px 16px",
                background: view===v ? "#C9A86E" : "none",
                color: view===v ? "#060606" : "#8A8480",
                border:"none", cursor:"pointer",
                fontSize:12, fontFamily:"Tajawal, sans-serif",
                fontWeight: view===v ? 700 : 400,
              }}>
                {v==="front" ? "الأمامي" : "الخلفي"}
              </button>
            ))}
          </div>

          {/* Guide toggle */}
          <button onClick={() => setShowGuide(g => !g)} style={{
            ...iconBtn, width:34, height:34,
            background: showGuide ? "#1A1200" : "#121212",
            border: `1px solid ${showGuide ? "#C9A86E40" : "#262626"}`,
            color: showGuide ? "#C9A86E" : "#8A8480",
            fontSize:10,
          }} title="منطقة الطباعة">
            ⊞
          </button>

          {/* Add to cart */}
          <button onClick={handleAddToCart} style={{
            display:"flex", alignItems:"center", gap:6,
            background:"linear-gradient(135deg, #C9A86E, #9A7848)",
            color:"#060606", border:"none", padding:"9px 18px", borderRadius:10,
            fontFamily:"Tajawal, sans-serif", fontWeight:700, fontSize:13,
            cursor:"pointer", boxShadow:"0 4px 16px #C9A86E30",
          }}>
            <ShoppingBag size={14}/>
            إضافة للسلة — {product.price.toLocaleString("ar-EG")} ج.م
          </button>
        </div>
      </div>

      <div style={{ display:"flex", height:"calc(100vh - 60px)" }}>

        {/* ═══ Left Panel ═══ */}
        <div style={{
          width:260, background:"#0D0D0D", borderLeft:"1px solid #1A1A1A",
          overflowY:"auto", flexShrink:0,
        }}>
          <div style={{ padding:14, display:"flex", flexDirection:"column", gap:18 }}>

            {/* Product type */}
            <Section title="اختر المنتج">
              <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:6 }}>
                {(Object.entries(PRODUCTS) as [ProductId, ProductDef][]).map(([id, p]) => (
                  <button key={id} onClick={() => { setProductId(id); setSize(p.sizes[Math.floor(p.sizes.length/2)]); }} style={{
                    padding:"8px 4px", background: productId===id ? "#1A1200" : "#121212",
                    border:`1px solid ${productId===id ? "#C9A86E" : "#1A1A1A"}`,
                    borderRadius:9, cursor:"pointer",
                    color: productId===id ? "#C9A86E" : "#8A8480",
                    fontSize:11, fontFamily:"Tajawal, sans-serif",
                    fontWeight: productId===id ? 700 : 400,
                    display:"flex", flexDirection:"column", alignItems:"center", gap:3,
                  }}>
                    <span style={{ fontSize:18 }}>{p.icon}</span>
                    <span>{p.label}</span>
                    <span style={{ fontSize:9, opacity:0.6 }}>{p.price.toLocaleString("ar-EG")} ج.م</span>
                  </button>
                ))}
              </div>
            </Section>

            {/* Size */}
            <Section title="المقاس">
              <div style={{ display:"flex", gap:5, flexWrap:"wrap" }}>
                {product.sizes.map(s => (
                  <button key={s} onClick={() => setSize(s)} style={{
                    padding:"5px 10px", borderRadius:7, cursor:"pointer",
                    background: size===s ? "#C9A86E" : "#121212",
                    border:`1px solid ${size===s ? "#C9A86E" : "#1A1A1A"}`,
                    color: size===s ? "#060606" : "#8A8480",
                    fontSize:11, fontFamily:"Tajawal, sans-serif",
                    fontWeight: size===s ? 700 : 400,
                    transition:"all 0.2s",
                  }}>
                    {s}
                  </button>
                ))}
              </div>
              {size !== "FREE SIZE" && (
                <p style={{ fontSize:10, color:"#484542", marginTop:6, fontFamily:"Tajawal, sans-serif" }}>
                  يعرض حجم {size} — التكبير/التصغير للعرض فقط
                </p>
              )}
            </Section>

            {/* Color */}
            <Section title="لون المنتج">
              <div style={{ display:"grid", gridTemplateColumns:"repeat(7,1fr)", gap:6 }}>
                {PRODUCT_COLORS.map(c => (
                  <button key={c.hex} onClick={() => setProdColor(c.hex)} title={c.name} style={{
                    width:28, height:28, borderRadius:"50%", background:c.hex,
                    border:"none", cursor:"pointer",
                    outline: prodColor===c.hex ? "2.5px solid #C9A86E" : "2px solid #262626",
                    outlineOffset: prodColor===c.hex ? 2 : 0,
                    transform: prodColor===c.hex ? "scale(1.18)" : "scale(1)",
                    transition:"all 0.2s",
                    boxShadow: prodColor===c.hex ? "0 0 0 4px #0D0D0D" : "none",
                  }}/>
                ))}
              </div>
            </Section>

            <div style={{ height:1, background:"#1A1A1A" }}/>

            {/* Tools */}
            <Section title="أدوات التصميم">
              <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:6 }}>
                {([
                  ["text",    "نص",       <Type size={13}/>   ],
                  ["sticker", "ستيكر",    <Smile size={13}/>  ],
                  ["upload",  "رفع صورة", <Upload size={13}/> ],
                ] as const).map(([v, l, icon]) => (
                  <button key={v} onClick={() => setTool(v as any)} style={{
                    display:"flex", alignItems:"center", gap:5,
                    padding:"8px 10px", borderRadius:9, cursor:"pointer",
                    background: tool===v ? "#1A1200" : "#121212",
                    border:`1px solid ${tool===v ? "#C9A86E" : "#1A1A1A"}`,
                    color: tool===v ? "#C9A86E" : "#8A8480",
                    fontSize:11, fontFamily:"Tajawal, sans-serif",
                    fontWeight: tool===v ? 600 : 400,
                  }}>{icon}{l}</button>
                ))}
              </div>
            </Section>

            {/* ── Text Tool ── */}
            {tool==="text" && (
              <div style={{ display:"flex", flexDirection:"column", gap:9 }}>
                <textarea
                  value={textInput} onChange={e => setTextInput(e.target.value)}
                  rows={2} dir="rtl" placeholder="اكتب نصك..."
                  style={{
                    background:"#121212", border:"1px solid #262626", borderRadius:9,
                    padding:"9px 11px", color:"#EDE8DF", fontSize:13,
                    fontFamily:"Tajawal, sans-serif", outline:"none", resize:"none", width:"100%", boxSizing:"border-box",
                  }}
                />
                <select value={fontFamily} onChange={e => setFontFamily(e.target.value)} style={{
                  background:"#121212", border:"1px solid #262626", borderRadius:9,
                  padding:"7px 10px", color:"#EDE8DF", fontSize:12,
                  fontFamily:"Tajawal, sans-serif", cursor:"pointer", outline:"none", width:"100%",
                }}>
                  {FONTS.map(f => <option key={f.name} value={f.name}>{f.label}</option>)}
                </select>
                <div style={{ display:"flex", alignItems:"center", gap:6 }}>
                  <button onClick={() => setFontSize(s => Math.max(10, s-2))} style={iconBtn}><Minus size={12}/></button>
                  <span style={{ flex:1, textAlign:"center", fontSize:12, color:"#EDE8DF" }}>{fontSize}px</span>
                  <button onClick={() => setFontSize(s => Math.min(110, s+2))} style={iconBtn}><Plus size={12}/></button>
                  <button onClick={() => setFontBold(b => !b)} style={{
                    ...iconBtn,
                    background: fontBold ? "#1A1200" : "#121212",
                    border:`1px solid ${fontBold ? "#C9A86E" : "#262626"}`,
                    color: fontBold ? "#C9A86E" : "#8A8480",
                  }}><Bold size={12}/></button>
                </div>
                <div style={{ display:"flex", gap:5, flexWrap:"wrap" }}>
                  {TEXT_COLORS.map(c => (
                    <button key={c} onClick={() => setTextColor(c)} style={{
                      width:24, height:24, borderRadius:"50%", background:c, cursor:"pointer",
                      border: textColor===c ? "2px solid #C9A86E" : "2px solid #262626",
                      transform: textColor===c ? "scale(1.22)" : "scale(1)",
                      transition:"all 0.2s",
                    }}/>
                  ))}
                </div>
                <button onClick={addText} style={{
                  width:"100%", background:"linear-gradient(135deg,#C9A86E,#9A7848)",
                  color:"#060606", border:"none", borderRadius:9,
                  padding:"10px", fontSize:13, fontFamily:"Tajawal, sans-serif", fontWeight:700, cursor:"pointer",
                }}>✦ إضافة النص</button>
              </div>
            )}

            {/* ── Sticker Tool ── */}
            {tool==="sticker" && (
              <div>
                <div style={{ display:"flex", gap:4, marginBottom:8, flexWrap:"wrap" }}>
                  {Object.keys(STICKER_PACKS).map(pack => (
                    <button key={pack} onClick={() => setStickerPack(pack)} style={{
                      padding:"4px 9px", borderRadius:20, cursor:"pointer",
                      background: stickerPack===pack ? "#C9A86E" : "#121212",
                      border:`1px solid ${stickerPack===pack ? "#C9A86E" : "#1A1A1A"}`,
                      color: stickerPack===pack ? "#060606" : "#8A8480",
                      fontSize:10, fontFamily:"Tajawal, sans-serif",
                      fontWeight: stickerPack===pack ? 700 : 400,
                    }}>{pack}</button>
                  ))}
                </div>
                <div style={{ display:"grid", gridTemplateColumns:"repeat(5,1fr)", gap:5 }}>
                  {STICKER_PACKS[stickerPack].map(emoji => (
                    <button key={emoji} onClick={() => addSticker(emoji)} style={{
                      aspectRatio:"1", borderRadius:9, background:"#121212",
                      border:"1px solid #1A1A1A", fontSize:22, cursor:"pointer",
                      display:"flex", alignItems:"center", justifyContent:"center", transition:"all 0.15s",
                    }}
                    onMouseEnter={e => {
                      (e.currentTarget as HTMLElement).style.background="#1A1200";
                      (e.currentTarget as HTMLElement).style.borderColor="#C9A86E";
                      (e.currentTarget as HTMLElement).style.transform="scale(1.1)";
                    }}
                    onMouseLeave={e => {
                      (e.currentTarget as HTMLElement).style.background="#121212";
                      (e.currentTarget as HTMLElement).style.borderColor="#1A1A1A";
                      (e.currentTarget as HTMLElement).style.transform="scale(1)";
                    }}>
                      {emoji}
                    </button>
                  ))}
                </div>
              </div>
            )}

            {/* ── Upload Tool ── */}
            {tool==="upload" && (
              <div>
                <input ref={fileInput} type="file" accept="image/*" style={{ display:"none" }} onChange={handleImageUpload}/>
                <button onClick={() => fileInput.current?.click()} style={{
                  width:"100%", border:"2px dashed #262626", borderRadius:12,
                  padding:"28px 0", background:"none", display:"flex", flexDirection:"column",
                  alignItems:"center", gap:8, color:"#8A8480", cursor:"pointer", transition:"all 0.2s",
                }}
                onMouseEnter={e => { (e.currentTarget as HTMLElement).style.borderColor="#C9A86E"; (e.currentTarget as HTMLElement).style.color="#C9A86E"; }}
                onMouseLeave={e => { (e.currentTarget as HTMLElement).style.borderColor="#262626"; (e.currentTarget as HTMLElement).style.color="#8A8480"; }}>
                  <Upload size={24}/>
                  <span style={{ fontSize:13, fontFamily:"Tajawal, sans-serif" }}>اضغط لرفع صورة</span>
                  <span style={{ fontSize:10, opacity:0.6 }}>PNG · JPG · SVG</span>
                </button>
              </div>
            )}

            {/* ── Selected Element Controls ── */}
            {selectedEl && (
              <div style={{ borderTop:"1px solid #1A1A1A", paddingTop:14, display:"flex", flexDirection:"column", gap:8 }}>
                <p style={{ fontSize:10, color:"#C9A86E", letterSpacing:"0.08em", fontFamily:"Tajawal, sans-serif" }}>
                  العنصر المحدد ← اسحب بالفأرة لتحريكه · استخدم ⬆ للتدوير
                </p>

                {/* Scale */}
                <div style={{ display:"flex", alignItems:"center", gap:6 }}>
                  <button onClick={() => scaleSelected(-0.1)} style={iconBtn}><Minus size={12}/></button>
                  <span style={{ flex:1, textAlign:"center", fontSize:11, color:"#8A8480", fontFamily:"Tajawal, sans-serif" }}>
                    الحجم {Math.round(selectedEl.scale * 100)}%
                  </span>
                  <button onClick={() => scaleSelected(0.1)} style={iconBtn}><Plus size={12}/></button>
                </div>

                {/* Rotation */}
                <div style={{ display:"flex", alignItems:"center", gap:6 }}>
                  <button onClick={() => rotateSelected(-15)} style={iconBtn}><RotateCcw size={12}/></button>
                  <span style={{ flex:1, textAlign:"center", fontSize:11, color:"#8A8480", fontFamily:"Tajawal, sans-serif" }}>
                    {selectedEl.rotation}°
                  </span>
                  <button onClick={() => rotateSelected(15)} style={iconBtn}><RotateCw size={12}/></button>
                </div>

                <button onClick={deleteSelected} style={{
                  width:"100%", display:"flex", alignItems:"center", justifyContent:"center", gap:5,
                  border:"1px solid #D0707030", borderRadius:9, background:"none",
                  padding:"8px", color:"#D07070", fontSize:12,
                  fontFamily:"Tajawal, sans-serif", cursor:"pointer",
                }}>
                  <Trash2 size={12}/> حذف العنصر
                </button>
              </div>
            )}

            {elements.length > 0 && (
              <button onClick={clearAll} style={{
                width:"100%", border:"1px solid #1A1A1A", borderRadius:9, background:"none",
                padding:"8px", color:"#484542", fontSize:12,
                fontFamily:"Tajawal, sans-serif", cursor:"pointer",
              }}>
                مسح كل التصميم
              </button>
            )}

            {/* Tip */}
            <div style={{ background:"#121212", border:"1px solid #1A1A1A", borderRadius:9, padding:"10px 12px" }}>
              <p style={{ fontSize:10, color:"#484542", fontFamily:"Tajawal, sans-serif", lineHeight:1.8, margin:0 }}>
                💡 <strong style={{ color:"#8A8480" }}>نصائح سريعة:</strong><br/>
                • اسحب العنصر لتحريكه<br/>
                • دولاب الفأرة لتكبير/تصغير العنصر<br/>
                • أزرار الدوران للتحريك
              </p>
            </div>
          </div>
        </div>

        {/* ═══ Center: Canvas ═══ */}
        <div style={{
          flex:1, display:"flex", alignItems:"center", justifyContent:"center",
          background:"#F2F0EC", position:"relative", overflow:"hidden",
        }}>
          {/* Grid bg */}
          <div style={{
            position:"absolute", inset:0, opacity:0.35,
            backgroundImage:`linear-gradient(#D8D6D0 1px,transparent 1px),linear-gradient(90deg,#D8D6D0 1px,transparent 1px)`,
            backgroundSize:"40px 40px",
          }}/>
          {/* Vignette */}
          <div style={{ position:"absolute", inset:0, background:"radial-gradient(ellipse at center,transparent 50%,#E8E6E0 100%)" }}/>

          {/* Labels */}
          <div style={{
            position:"absolute", top:12, left:"50%", transform:"translateX(-50%)",
            background:"#00000010", borderRadius:20, padding:"4px 14px",
          }}>
            <span style={{ fontSize:10, color:"#666", fontFamily:"Tajawal, sans-serif" }}>
              {view==="front" ? "الوجه الأمامي" : "الوجه الخلفي"} — {product.label} — مقاس {size}
            </span>
          </div>

          {/* Canvas */}
          <div
            ref={canvasRef}
            style={{
              position:"relative",
              width: 380 * sizeScale,
              height: productId==="cap" ? 340 * sizeScale : 490 * sizeScale,
              cursor: "default",
              userSelect:"none",
              transition:"width 0.4s cubic-bezier(0.22,1,0.36,1), height 0.4s cubic-bezier(0.22,1,0.36,1)",
            }}
            onMouseMove={onMouseMove}
            onMouseUp={onMouseUp}
            onMouseLeave={onMouseUp}
            onWheel={onWheel as any}
            onClick={() => setSelected(null)}
          >
            {/* Product SVG */}
            <div
              style={{ position:"absolute", inset:0, pointerEvents:"none" }}
              dangerouslySetInnerHTML={{ __html: svgHtml }}
            />

            {/* Print area guide */}
            {showGuide && (
              <div style={{
                position:"absolute",
                top:`${product.printArea.top}%`,
                left:`${product.printArea.left}%`,
                width:`${product.printArea.width}%`,
                height:`${product.printArea.height}%`,
                border:"1.5px dashed rgba(201,168,110,0.5)",
                borderRadius:4, pointerEvents:"none",
                boxShadow:"inset 0 0 0 1px rgba(201,168,110,0.1)",
              }}>
                <span style={{
                  position:"absolute", top:-16, left:"50%", transform:"translateX(-50%)",
                  fontSize:8, color:"rgba(201,168,110,0.7)", whiteSpace:"nowrap",
                  fontFamily:"Tajawal, sans-serif",
                }}>منطقة الطباعة</span>
              </div>
            )}

            {/* Design elements */}
            {elements.map(el => (
              <div
                key={el.id}
                onMouseDown={e => onMouseDown(e, el.id)}
                onClick={e => { e.stopPropagation(); setSelected(el.id); }}
                style={{
                  position:"absolute", left:el.x, top:el.y,
                  transform:`translate(-50%,-50%) scale(${el.scale}) rotate(${el.rotation}deg)`,
                  cursor:"move", userSelect:"none",
                  outline: selected===el.id ? "1.5px dashed #C9A86E" : "none",
                  outlineOffset:6, borderRadius:4,
                  padding: selected===el.id ? 4 : 0,
                }}
              >
                {el.type==="text" && (
                  <span style={{
                    fontSize:el.fontSize, color:el.color,
                    fontFamily:el.fontFamily||"Tajawal, sans-serif",
                    fontWeight:el.bold ? 700 : 400,
                    whiteSpace:"nowrap", display:"block",
                    filter:"drop-shadow(0 1px 3px rgba(0,0,0,0.18))",
                  }}>
                    {el.content}
                  </span>
                )}
                {el.type==="sticker" && (
                  <span style={{ fontSize:el.fontSize, lineHeight:1, display:"block",
                    filter:"drop-shadow(0 2px 6px rgba(0,0,0,0.16))" }}>
                    {el.content}
                  </span>
                )}
                {el.type==="image" && (
                  // eslint-disable-next-line @next/next/no-img-element
                  <img src={el.content} alt="" style={{
                    width:el.fontSize*2.2, height:el.fontSize*2.2,
                    objectFit:"contain", display:"block",
                    filter:"drop-shadow(0 2px 8px rgba(0,0,0,0.2))",
                  }}/>
                )}

                {/* Corner handles */}
                {selected===el.id && (
                  <>
                    {[{top:-7,left:-7},{top:-7,right:-7},{bottom:-7,left:-7},{bottom:-7,right:-7}].map((pos,i) => (
                      <div key={i} style={{
                        position:"absolute", ...pos,
                        width:11, height:11, borderRadius:"50%",
                        background:"#C9A86E", border:"2.5px solid #fff",
                        pointerEvents:"none", boxShadow:"0 1px 4px #0004",
                      }}/>
                    ))}
                  </>
                )}
              </div>
            ))}
          </div>

          <p style={{
            position:"absolute", bottom:12,
            fontSize:10, color:"#999", fontFamily:"Tajawal, sans-serif",
          }}>
