  PROCESSING: "تجهيز",
  SHIPPED:    "شحن",
  DELIVERED:  "تسليم",
  CANCELLED:  "ملغي",
};

// ─── Stat Card ────────────────────────────────────────────────
function StatCard({
  title,
  value,
  sub,
  icon: Icon,
  color,
  delay,
}: {
  title: string;
  value: string | number;
  sub: string;
  icon: React.ElementType;
  color: string;
  delay: number;
}) {
  return (
    <motion.div
      initial={{ opacity: 0, y: 14 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ delay }}
      className="bg-[#0D0D0D] border border-[#1A1A1A] rounded-2xl p-5 hover:border-[#262626] transition-colors"
    >
      <div className="flex items-start justify-between mb-4">
