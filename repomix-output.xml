              <span style={{ fontSize:12, color:"#8A8480", fontFamily:"Tajawal, sans-serif" }}>اللون</span>
              <div style={{ width:22, height:22, borderRadius:"50%", background:prodColor, border:"2px solid #262626" }}/>
            </div>
          </Section>

          <div style={{ height:1, background:"#1A1A1A" }}/>

          <div>
            <p style={{ fontSize:9, color:"#484542", marginBottom:6, fontFamily:"Tajawal, sans-serif" }}>السعر</p>
            <div style={{ fontFamily:"'Cormorant Garant', serif", fontSize:28, color:"#C9A86E" }}>
              {product.price.toLocaleString("ar-EG")}
              <span style={{ fontSize:13, fontFamily:"Tajawal, sans-serif", marginRight:3 }}>ج.م</span>
            </div>
            <p style={{ fontSize:9, color:"#484542", marginTop:3, fontFamily:"Tajawal, sans-serif" }}>شامل التصميم والطباعة</p>
          </div>

          <button onClick={handleAddToCart} style={{
            display:"flex", alignItems:"center", justifyContent:"center", gap:5,
            background:"linear-gradient(135deg,#C9A86E,#9A7848)",
            color:"#060606", border:"none", borderRadius:10,
            padding:"11px", fontSize:13,
            fontFamily:"Tajawal, sans-serif", fontWeight:700, cursor:"pointer",
            boxShadow:"0 4px 16px #C9A86E25",
          }}>
            <ShoppingBag size={13}/> أضف للسلة
          </button>

          <div style={{ display:"flex", flexDirection:"column", gap:6 }}>
            {["✅ طباعة DTF عالية الجودة","✅ توصيل خلال 5-7 أيام","✅ ضمان 30 يوم","✅ إلغاء مجاني"].map(t => (
              <p key={t} style={{ fontSize:10, color:"#484542", fontFamily:"Tajawal, sans-serif" }}>{t}</p>
            ))}
          </div>
        </div>
      </div>
    </div>
  );
}
