          className="w-full flex items-center justify-center gap-2 bg-[#C9A86E] text-[#060606] rounded-2xl py-4 text-[14px] font-bold font-tajawal hover:brightness-110 transition-all disabled:opacity-60 shadow-[0_8px_24px_#9A784840]"
        >
          {saving ? (
            <Loader2 size={18} className="animate-spin" />
          ) : (
            <>
              <Save size={16} />
