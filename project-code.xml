                    : `${order.shippingCost} ج.م`}
                </span>
              </div>
              {order.discount > 0 && (
                <div
                  style={{
                    display: "flex",
                    justifyContent: "space-between",
                    fontSize: 12,
                    fontFamily: "Tajawal, sans-serif",
