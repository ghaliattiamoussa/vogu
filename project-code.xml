              <div style={{ maxWidth: 480 }}>

                {/* Badge */}
                <div style={{
                  display: "inline-flex", alignItems: "center", gap: 6,
                  fontSize: 11, color: C.gold, letterSpacing: "0.22em",
                  fontFamily: "Tajawal, sans-serif", marginBottom: 20,
