            <div style={{ flex: 1, minWidth: 0 }}>
              <p style={{ fontSize: 13, fontWeight: 700, color: C.t1, fontFamily: 'Tajawal, sans-serif', margin: '0 0 3px' }}>
                تحديث جديد على طلبك
