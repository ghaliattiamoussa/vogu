import { NextRequest, NextResponse } from 'next/server';
import bcrypt from 'bcryptjs';
import crypto from 'crypto';
import { prisma } from '@/lib/db';
import { sendVerificationEmail } from '@/lib/mail';

export async function POST(req: NextRequest) {
  try {
    const { name, email, password } = await req.json();

    // ── التحقق من البيانات ──
    if (!name?.trim() || !email?.trim() || !password) {
      return NextResponse.json(
        { error: 'جميع الحقول مطلوبة' },
        { status: 400 },
      );
    }

    if (password.length < 8) {
      return NextResponse.json(
        { error: 'كلمة المرور يجب أن تكون 8 أحرف على الأقل' },
        { status: 400 },
      );
    }

    const emailLower = email.toLowerCase().trim();

    // ── تحقق من عدم تكرار البريد ──
    const existing = await prisma.user.findUnique({
      where: { email: emailLower },
    });

    if (existing) {
      return NextResponse.json(
        { error: 'هذا البريد الإلكتروني مسجّل بالفعل' },
        { status: 409 },
      );
    }

    // ── تشفير كلمة المرور ──
    const hashedPassword = await bcrypt.hash(password, 12);

    // ── إنشاء المستخدم (emailVerified = null حتى يتحقق) ──
    await prisma.user.create({
      data: {
        name:          name.trim(),
        email:         emailLower,
        password:      hashedPassword,
        emailVerified: null,   // ← لم يتحقق بعد
      },
    });

    // ── إنشاء توكن التحقق ──
    const token   = crypto.randomBytes(32).toString('hex');
    const expires = new Date(Date.now() + 24 * 60 * 60 * 1000); // 24 ساعة

    await prisma.verificationToken.upsert({
      where:  { identifier_token: { identifier: emailLower, token: emailLower } },
      update: { token, expires },
      create: { identifier: emailLower, token, expires },
    });

    // ── إرسال إيميل التحقق عبر Resend ──
    await sendVerificationEmail(emailLower, name.trim(), token);

    return NextResponse.json(
      {
        success: true,
        message: 'تم إنشاء الحساب. تحقق من بريدك الإلكتروني لتفعيله.',
      },
      { status: 201 },
    );

  } catch (err) {
    console.error('[register]', err);
    return NextResponse.json(
      { error: 'حدث خطأ في الخادم، حاول مجدداً' },
      { status: 500 },
    );
  }
}
</file>

