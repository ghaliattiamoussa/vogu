          }}
          transition={{ duration: 2.2, repeat: Infinity, ease: 'easeInOut' }}
          style={{ position: 'relative', borderRadius: 50, marginRight: -278 }}
        >
          <Link
            href="/customize"
            style={{
              display: 'flex', alignItems: 'center', gap: 6,
              background: 'linear-gradient(135deg, #C9A86E, #A8823C, #8A6830)',
