import { formatPrice, calcDiscount } from "@/lib/utils";

// ── الألوان — ثيم فاتح (مطابقة لـ tailwind.config.ts) ──────────────
const C = {
  bg:    "#FAFAF8",
  surf:  "#F5F3EF",
  card:  "#FFFFFF",
  b1:    "#EAE7E1",
  b2:    "#DDD9D1",
  gold:  "#A8823C",
  goldL: "#C9A86E",
  t1:    "#1A1714",
  t2:    "#6B6560",
