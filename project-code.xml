            {/* زر تسجيل الدخول */}
            <motion.button
              type="submit"
              disabled={loading}
              whileTap={{ scale: 0.98 }}
              style={{
                width:        '100%',
                background:   loading
                  ? C.b2
                  : `linear-gradient(135deg, ${C.gold}, ${C.goldD})`,
                color:        loading ? C.t3 : '#FFFFFF',
                border:       'none',
                borderRadius: 10,
                padding:      '14px',
                fontSize:     14,
                fontFamily:   'Tajawal, sans-serif',
                fontWeight:   700,
                cursor:       loading ? 'not-allowed' : 'pointer',
                transition:   'all 0.2s',
                letterSpacing:'0.02em',
              }}
