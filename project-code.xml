const CUSTOMIZER_PRODUCT_ALIASES: Record<string, ProductId> = {
  "tshirt-classic": "tshirt",
  "tshirt-oversized": "tshirt",
  "tshirt-polo": "polo",
  "tshirt-longsleeve": "longsleeve",
};

const resolveCustomizerProductId = (id?: string | null, svgType?: string | null): ProductId | null => {
  if (id && PRODUCTS[id as ProductId]) return id as ProductId;
  if (id && CUSTOMIZER_PRODUCT_ALIASES[id]) return CUSTOMIZER_PRODUCT_ALIASES[id];
  if (svgType && PRODUCTS[svgType as ProductId]) return svgType as ProductId;
  return null;
};

