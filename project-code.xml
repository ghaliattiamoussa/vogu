                  fontFamily: 'Tajawal, sans-serif',
                }}
              >
                {item.text}
              </span>
              <span style={{ color: C.gold, fontSize: 14 }}>{item.icon}</span>
            </motion.div>
          ))}
        </motion.div>
      </div>

      {/* ══ يسار: فورم تسجيل الدخول ══ */}
      <div
        style={{
          width:          '100%',
          maxWidth:       460,
          display:        'flex',
          flexDirection:  'column',
          justifyContent: 'center',
          padding:        '48px 40px',
