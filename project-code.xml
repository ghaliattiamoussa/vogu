            <p style={{ fontSize: 13, color: C.t2, fontFamily: 'Tajawal, sans-serif' }}>
              سجّل دخولك للوصول إلى حسابك وطلباتك
            </p>
          </div>

          {/* رسالة خطأ الـ URL (مثلاً إذا انتهت الجلسة) */}
          {searchParams.get('error') === 'SessionRequired' && (
            <div
