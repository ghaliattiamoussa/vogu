// ============================================================
// VOGU Store — Central TypeScript Types
// ============================================================

export type Role = "USER" | "ADMIN";
export type OrderStatus =
  | "PENDING"
  | "CONFIRMED"
  | "PROCESSING"
  | "SHIPPED"
  | "DELIVERED"
  | "CANCELLED";
export type CouponType = "PERCENTAGE" | "FIXED";

// ── User ─────────────────────────────────────────────────────
export interface User {
  id: string;
  name: string | null;
  email: string;
  role: Role;
  image: string | null;
  createdAt: Date;
}

// ── Product ───────────────────────────────────────────────────
export interface ProductImage {
  id: string;
  url: string;
  alt: string | null;
