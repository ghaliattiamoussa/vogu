                key={method}
                style={{
                  fontSize:     10,
                  color:        C.t2,
                  fontFamily:   'Tajawal, sans-serif',
                  background:   C.card,
                  padding:      '3px 9px',
                  borderRadius: 5,
                  border:       `1px solid ${C.b2}`,
                }}
              >
                {method}
              </span>
            ))}
          </div>
        </div>

      </div>
    </footer>
  );
}
