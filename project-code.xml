export const couponSchema = z
  .object({
    code:           z
      .string()
      .min(3, 'الكود يجب أن يكون 3 أحرف على الأقل')
      .max(20)
      .regex(/^[A-Z0-9_-]+$/, 'الكود يجب أن يحتوي على أحرف كبيرة وأرقام فقط'),
    type:           z.enum(['PERCENTAGE', 'FIXED']),
