import { getServerSession } from "next-auth";
import { authOptions } from "@/lib/auth";

// ══════════════════════════════════════════════════════════════
// POST /api/support — استقبال رسائل الدعم من الـ Chat Widget
// ══════════════════════════════════════════════════════════════
// ملاحظة: هذا endpoint بسيط يسجّل الرسالة في الـ console فقط.
// لتفعيل إشعارات حقيقية، اختر واحدة من الخيارات بالأسفل:
//
