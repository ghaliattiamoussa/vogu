                    onBlur={() => { if (!searchQuery) setSearchOpen(false); }}
                    placeholder="ابحث..."
                    dir="rtl"
                    style={{
                      background: C.surf, border: `1px solid ${C.b2}`,
                      borderRadius: 7, padding: '5px 9px 5px 26px',
                      color: C.t1, fontSize: 12, fontFamily: 'Tajawal, sans-serif',
                      outline: 'none', width: '100%',
