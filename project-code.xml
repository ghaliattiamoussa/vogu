import { Copy, Check, AlertCircle } from "lucide-react";

// ─── Light theme palette (نفس ألوان باقي الموقع) ──────────────
const C = {
  card: "#FFFFFF",
  surf: "#F5F3EF",
  b1:   "#EAE7E1",
  b2:   "#DDD9D1",
  gold: "#A8823C",
