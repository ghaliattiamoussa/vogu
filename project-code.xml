// ── تعريف الطرق ───────────────────────────────────────────
const GROUPS = [
  {
    label: "المحافظ الإلكترونية",
    methods: [
      { id: "instapay" as PayMethod,      label: "InstaPay",       icon: "⚡", desc: "تحويل فوري عبر InstaPay" },
