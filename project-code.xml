        >
          <ArrowLeft size={14} />
          رجوع للمتجر
        </Link>

        <motion.div
          initial={{ opacity: 0, y: 16 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.5 }}
        >
          {/* العنوان */}
          <div style={{ marginBottom: 36 }}>
            <div
              style={{
